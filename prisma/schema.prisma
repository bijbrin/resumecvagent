generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  // No url here — Prisma 7 reads the connection via prisma.config.ts for
  // the CLI, and via the PrismaNeon adapter at runtime.
  provider = "postgresql"
}

// ─── User ─────────────────────────────────────────────────────────────────────
// id is the Clerk userId — no separate DB-generated ID needed.
// PII (full name, email) is kept here only as a display cache; Clerk is
// the source of truth for identity.
model User {
  id        String   @id       // Clerk userId
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  runs         OptimizationRun[]
  resumes      Resume[]
  applications JobApplication[]
}

// ─── JobApplication ───────────────────────────────────────────────────────────
// One row per tracked job application. The DB is the system of record for
// application METADATA only — the markdown content (JD, resume, cover letter,
// review) lives on disk in the job folder (folderPath). This preserves the
// "no resume/cover-letter PII in PostgreSQL columns" invariant: we store the
// folder path + per-file content hashes, never the document bodies.
model JobApplication {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  slug    String  // folder name under the workspace root, e.g. "giveagrab"
  company String
  role    String?
  jobUrl  String?

  location String?
  salary   String?
  status   ApplicationStatus @default(DRAFT)

  appliedAt DateTime?
  deadline  DateTime?

  contactName  String?
  contactEmail String?
  notes        String?

  folderPath String // absolute path to the job folder on disk
  fileHashes Json?  // { "Resume.md": "sha256…", … } for change detection

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  runs OptimizationRun[]

  @@unique([userId, slug])
  @@index([userId, status])
}

enum ApplicationStatus {
  DRAFT
  TAILORING
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
  ARCHIVED
}

// ─── Resume ───────────────────────────────────────────────────────────────────
// A user's saved resume — either text they pasted into the optimizer, or text
// extracted from an uploaded PDF/DOCX. Unlimited history per user.
// `content` stores the extracted plain text (not the original binary).
model Resume {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String       // filename if uploaded; "Pasted <ISO date>" if typed
  source    ResumeSource
  content   String       // extracted plain text — postgres text by default

  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([userId, createdAt])
}

enum ResumeSource {
  TEXT
  PDF
  DOCX
}

// ─── OptimizationRun ──────────────────────────────────────────────────────────
// One row per optimization job. correlationId is what we expose via the API
// and stream back in progress events — keeps internal DB ids private.
model OptimizationRun {
  id            String    @id @default(cuid())
  correlationId String    @unique @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])

  // Optional link to a tracked application. Set when a run is launched from
  // the Applications workspace ("re-run agents") rather than the ad-hoc optimizer.
  jobApplicationId String?
  jobApplication   JobApplication? @relation(fields: [jobApplicationId], references: [id], onDelete: SetNull)

  jobUrl      String
  companyName String?
  status      RunStatus @default(PENDING)
  warnings    String[]  // agent warnings collected during the run

  // Live progress map updated during graph execution.
  // Agents update this as they complete so the status endpoint can stream progress.
  agentStatusJson Json?

  // Full result object stored when the run completes.
  // Interim measure — architecture targets blob storage for artifacts.
  resultJson      Json?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  artifacts OptimizationArtifact[]

  @@index([userId])
  @@index([jobApplicationId])
}

enum RunStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

// ─── OptimizationArtifact ─────────────────────────────────────────────────────
// Stores pointers to blob storage (Vercel Blob / S3), never the file content.
// Full resume/cover letter text is PII and lives only in blob storage with TTL.
model OptimizationArtifact {
  id    String @id @default(cuid())
  runId String
  run   OptimizationRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  type      ArtifactType
  url       String    // blob storage URL
  expiresAt DateTime? // TTL — null means no expiry

  createdAt DateTime @default(now())
}

enum ArtifactType {
  RESUME
  COVER_LETTER
  INTERVIEW_PREP
  COMBINED_REPORT
}
