# Copy this file to .env.local and fill in the values.
# Never commit .env.local — it is in .gitignore by default.

# ── Database (Neon) ───────────────────────────────────────────────────────────
# Pooled — used by the app at runtime via PrismaNeon adapter
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
# Direct — used by Prisma CLI only (migrations, db push, introspection)
DIRECT_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# ── LLM Providers ─────────────────────────────────────────────────────────────
# OpenRouter is the PRIMARY provider (OpenAI-compatible gateway). Fallback order:
# OpenRouter → Kimi → OpenAI → Anthropic. At least one key below must be set.
OPENROUTER_API_KEY=sk-or-...    # https://openrouter.ai/keys
# OPENROUTER_MODEL=deepseek/deepseek-v4-flash      # primary model (default)
# OPENROUTER_REASONING_MODEL=deepseek/deepseek-v4-flash  # stronger tier (defaults to primary)
# OPENROUTER_FALLBACK_MODEL=deepseek/deepseek-v3.2 # in-provider fallback model
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1 # override gateway
# OPENROUTER_SITE_URL=http://localhost:3000        # attribution (dashboard)
# OPENROUTER_APP_NAME=ResumeCVAgent                # attribution (dashboard)

ANTHROPIC_API_KEY=sk-ant-...   # optional fallback
OPENAI_API_KEY=sk-...          # optional
KIMI_API_KEY=                  # optional — Moonshot/Kimi key (platform.kimi.ai)
# KIMI_BASE_URL=https://api.moonshot.ai/v1   # override; use .cn for China-region keys
# KIMI_MODEL_OVERRIDE=kimi-k2.6              # override; default is kimi-k2.6

# ── Kimi Feature Flags ────────────────────────────────────────────────────────
USE_KIMI_STRATEGY=false
USE_KIMI_WRITER=false
USE_KIMI_COVER_LETTER=false

# ── Artifact Storage ──────────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=         # Vercel Blob token (required in production)

# ── Optional Enrichment Services ──────────────────────────────────────────────
FIRECRAWL_API_KEY=             # deeper web scraping
SERPER_API_KEY=                # Google search results

# ── Auth (Clerk) ──────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/optimizer
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/optimizer

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
LOG_LEVEL=info                 # debug | info | warn | error

# ── Feature Request Email (Gmail SMTP) ────────────────────────────────────────
# Used by /api/feedback to send "Request a feature" messages to the recipient
# hardcoded in app/api/feedback/route.ts.
# Generate a 16-char Google App Password at:
#   https://myaccount.google.com/apppasswords  (requires 2FA enabled)
GMAIL_USER=your@email.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx   # 16-char app password (spaces removed)
